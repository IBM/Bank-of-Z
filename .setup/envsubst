#!/usr/bin/env python3
"""
envsubst - Substitute ${VAR} references in a file using build.conf values
Reads a file, expands ${VAR} placeholders from build.conf, and writes the result to stdout.
This is a generalized version that can be used for any file type (SQL, CSD, JCL, etc.)

Usage: envsubst <input_file> [--config <build.conf>]
Copyright IBM Corp. 2023, 2025
"""

import os
import sys
import re
import argparse
from pathlib import Path


def load_config(config_file: str) -> dict:
    """Load and expand variables from build.conf"""
    config = {}
    if not os.path.exists(config_file):
        print(f"ERROR: Configuration file not found: {config_file}", file=sys.stderr)
        sys.exit(1)

    pattern = re.compile(r'\$\{([^}]+)\}')

    def expand(value: str) -> str:
        def replace(match):
            var = match.group(1)
            if var in config:
                return config[var]
            return os.environ.get(var, match.group(0))
        prev = None
        while prev != value:
            prev = value
            value = pattern.sub(replace, value)
        return value

    with open(config_file, 'r') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            if '=' in line:
                key, value = line.split('=', 1)
                config[key.strip()] = expand(value.strip())

    # Expose $USER from environment if not already set
    if 'USER' not in config and 'USER' in os.environ:
        config['USER'] = os.environ['USER']

    return config


def substitute(content: str, config: dict) -> str:
    """Replace ${VAR} in content with values from config"""
    pattern = re.compile(r'\$\{([^}]+)\}')

    def replace(match):
        var = match.group(1)
        if var in config:
            return config[var]
        val = os.environ.get(var)
        if val is not None:
            return val
        print(f"WARNING: Variable ${{{var}}} not found in configuration", file=sys.stderr)
        return match.group(0)

    return pattern.sub(replace, content)


def main():
    parser = argparse.ArgumentParser(
        description='Substitute ${VAR} in a file using build.conf values, write to stdout'
    )
    parser.add_argument(
        'input_file',
        help='Input file to process (SQL, CSD, JCL, or any text file)'
    )
    parser.add_argument(
        '--config', '-c',
        default=None,
        help='Path to build.conf (default: build.conf in parent directory of this script)'
    )
    args = parser.parse_args()

    # Resolve config path
    if args.config:
        config_path = args.config
    else:
        script_dir = Path(__file__).resolve().parent.parent
        config_path = str(script_dir / 'build.conf')

    # Load configuration
    config = load_config(config_path)

    # Read input file
    input_file = args.input_file
    if not os.path.exists(input_file):
        print(f"ERROR: Input file not found: {input_file}", file=sys.stderr)
        sys.exit(1)

    with open(input_file, 'r') as f:
        content = f.read()

    # Substitute and write to stdout
    result = substitute(content, config)
    sys.stdout.write(result)


if __name__ == '__main__':
    main()

