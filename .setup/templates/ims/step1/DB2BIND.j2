//*********************************************************************
//*                                                                   *
//* BIND Db2 PLANS - REPLACE IF EXIST                                 *
//* GRANT EXECUTE IBGHIST PLAN                                        *
//*                                                                   *
//*********************************************************************
//BINDPL   EXEC PGM=IKJEFT01,DYNAMNBR=20
//STEPLIB  DD  DISP=SHR,DSN={{ DSNEXIT }} 
//         DD  DISP=SHR,DSN={{ DSNLOD2 }}
//         DD  DISP=SHR,DSN={{ DSNLOAD }}
//SYSTSPRT DD  SYSOUT=*
//SYSPRINT DD  SYSOUT=*
//SYSUDUMP DD  SYSOUT=*
//SYSTSIN  DD  *
  DSN SYSTEM({{ DB2SSID }})
    BIND PLAN (IBTRAN) KEEPDYNAMIC(YES) -
    ACTION(REPLACE) PKLIST(NULLID.*)
    BIND PLAN (IBGHIST) KEEPDYNAMIC(YES) -
    ACTION(REPLACE) PKLIST(NULLID.*)
    BIND PLAN (IBSHIST) KEEPDYNAMIC(YES) -
    ACTION(REPLACE) PKLIST(NULLID.*)
  END
